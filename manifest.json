{
	"manifest_version": 3,
	"name": "Cambridge Audio Downloader",
	"version": "1.0",
	"description": "Extension to download audio files from Cambridge Dictionary",
	"permissions": ["storage", "activeTab", "scripting"],
	"action": {
		"default_popup": "popup/popup.html",
		"default_icon": {
			"16": "assets/16.png",
			"48": "assets/48.png",
			"128": "assets/128.png"
		}
	},
	"icons": {
        "16": "assets/16.png",
		"48": "assets/48.png",
		"128": "assets/128.png"
    },
	"background": {
		"service_worker": "content/background.js"
	},
	"web_accessible_resources": [
		{
			"resources": ["assets/*"],
			"matches": ["https://dictionary.cambridge.org/*"]
		}
	]
}
